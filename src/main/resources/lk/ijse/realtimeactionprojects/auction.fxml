<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="800.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.realtimeactionprojects.controller.AuctionController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <children>
                
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 15px; -fx-border-color: #dcdde1; -fx-border-width: 0 0 1px 0;">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="LIVE AUCTION ROOM" style="-fx-text-fill: #1e3a8a; -fx-font-weight: bold; -fx-font-size: 20px;" />
                                <Label fx:id="lblWelcome" text="Welcome, User!" style="-fx-text-fill: #4b5563; -fx-font-size: 13px;" />
                            </children>
                        </VBox>
                        <Button fx:id="btnNewClient" mnemonicParsing="false" onAction="#handleOpenNewClientWindow" text="NEW CLIENT" style="-fx-background-color: #6b7280; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-padding: 8px 16px; -fx-background-radius: 4px; -fx-cursor: hand;" />
                        <Button fx:id="btnDisconnect" mnemonicParsing="false" onAction="#handleDisconnect" text="DISCONNECT" style="-fx-background-color: #dc2626; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-padding: 8px 16px; -fx-background-radius: 4px; -fx-cursor: hand;" />
                    </children>
                </HBox>

                <HBox fx:id="bannerContainer" alignment="CENTER" visible="false" managed="false" style="-fx-background-color: #fef3c7; -fx-border-color: #f59e0b; -fx-border-width: 1px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 12px;">
                    <children>
                        <Label fx:id="lblBanner" style="-fx-text-fill: #b45309; -fx-font-weight: bold; -fx-font-size: 15px;" text="AUCTION CLOSED!" />
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                         
                         <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-padding: 20px; -fx-background-radius: 8px; -fx-border-color: #e5e7eb; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
                             <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-weight: bold;" text="Item Details" />
                                <GridPane hgap="10.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120.0" prefWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="25.0" />
                                        <RowConstraints minHeight="25.0" />
                                    </rowConstraints>
                                    <children>
                                        <Label text="Item Name:" style="-fx-text-fill: #4b5563; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="lblItemName" style="-fx-font-size: 15px; -fx-text-fill: #1e3a8a; -fx-font-weight: bold;" text="Vintage Watch" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        
                                        <Label text="Starting Price:" style="-fx-text-fill: #4b5563; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="lblStartingPrice" style="-fx-font-size: 15px; -fx-text-fill: #1e3a8a; -fx-font-weight: bold;" text="LKR 5000.00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                             </children>
                         </VBox>

                         <VBox prefWidth="320.0" HBox.hgrow="NEVER" style="-fx-background-color: #ecfdf5; -fx-padding: 20px; -fx-background-radius: 8px; -fx-border-color: #10b981; -fx-border-width: 2px; -fx-effect: dropshadow(three-pass-box, rgba(16,185,129,0.1), 8, 0, 0, 0);">
                             <children>
                                 <Label style="-fx-text-fill: #065f46; -fx-font-weight: bold; -fx-font-size: 12px;" text="CURRENT HIGHEST BID" />
                                 <Label fx:id="lblHighestBid" style="-fx-text-fill: #059669; -fx-font-size: 28px; -fx-font-weight: 800; -fx-padding: 8px 0 0 0;" text="LKR 5000.00" />
                                 <HBox spacing="5.0" style="-fx-padding: 5 0 0 0;">
                                     <children>
                                         <Label text="Bidder:" style="-fx-text-fill: #065f46; -fx-font-size: 13px;" />
                                         <Label fx:id="lblHighestBidder" style="-fx-text-fill: #047857; -fx-font-weight: bold; -fx-font-size: 13px;" text="No bids yet" />
                                     </children>
                                 </HBox>
                             </children>
                         </VBox>
                    </children>
                </HBox>

                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Live Bidding Logs" style="-fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 14px;" />
                        <TextArea fx:id="txtAreaLogs" editable="false" prefHeight="250.0" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1f2937; -fx-border-color: #d1d5db; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-font-family: monospace; -fx-font-size: 13px;" />
                    </children>
                </VBox>

                <HBox fx:id="inputPanel" alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: #e5e7eb; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
                    <children>
                        <Label text="Place Your Bid (LKR):" style="-fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 13px;" />
                        <TextField fx:id="txtBidAmount" promptText="Enter bid amount (e.g. 5500)" HBox.hgrow="ALWAYS" onAction="#handlePlaceBid" style="-fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-padding: 8px;" />
                        <Button fx:id="btnPlaceBid" mnemonicParsing="false" onAction="#handlePlaceBid" text="PLACE BID" style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-padding: 8px 16px; -fx-background-radius: 4px; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
